---
import Layout from '../../layouts/Layout.astro';
import { getProductBySlug, formatPrice, mainImage } from '../../lib/data';

const { slug } = Astro.params;
const product = slug ? await getProductBySlug(slug) : null;
if (!product) return Astro.redirect('/catalog');

const images = product.images ?? [];
const features = (product.description ?? '').split('\n').map((s) => s.trim()).filter(Boolean);
---
<Layout title={`${product.name} — Керамика`} active="catalog">
  <div class="cer-page-header">
    <div class="cer-container">
      <span class="cer-section__subtitle"><a href="/catalog">Каталог</a></span>
    </div>
  </div>

  <section class="cer-section cer-section--no-top">
    <div class="cer-container">
      <div class="cer-product">
        <div class="cer-product__gallery cer-fade-left">
          <img src={mainImage(product)} alt={product.name} class="cer-product__main-image" />
          {images.length > 1 && (
            <div class="cer-product__thumbs">
              {images.map((img, i) => (
                <img src={img} alt={product.name} class={`cer-product__thumb ${i === 0 ? 'cer-product__thumb--active' : ''}`} />
              ))}
            </div>
          )}
        </div>

        <div class="cer-product__info cer-fade-right">
          {product.category && <div class="cer-product__category">{product.category}</div>}
          <h1 class="cer-product__name">{product.name}</h1>
          <span class="cer-product__price">{formatPrice(product.price)}</span>
          {features.length > 0 && (
            <ul class="cer-product__features">
              {features.map((line) => <li>{line}</li>)}
            </ul>
          )}
          <div class="cer-product__actions">
            <a href={`/order?product=${product.slug}`} class="cer-btn cer-btn--primary">Заказать</a>
            <a href="/catalog" class="cer-btn cer-btn--outline">Назад в каталог</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
