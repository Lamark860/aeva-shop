---
import { formatPrice, mainImage, type Product } from '../lib/data';
interface Props { product: Product; showCategory?: boolean; }
const { product, showCategory = false } = Astro.props;
---
<a href={`/product/${product.slug}`} class="cer-card">
  <div class="cer-card__image-wrap">
    <img src={mainImage(product)} alt={product.name} class="cer-card__image" loading="lazy" />
  </div>
  <div class="cer-card__info">
    {showCategory && product.category && <span class="cer-card__category">{product.category}</span>}
    <h3 class="cer-card__name">{product.name}</h3>
    <span class="cer-card__price">{formatPrice(product.price)}</span>
  </div>
</a>
