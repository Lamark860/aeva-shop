# src/payload-types.ts — НЕ игнорируем: генерится payload generate:types, но коммитим,
# чтобы next build (CI и прод-образ) проходил типизацию без БД/регенерации.
# После изменения коллекций: npm run generate:types → закоммитить обновлённый файл.

# загруженные через админку медиафайлы (dev)
/media/
/uploads/

# build artifact
*.tsbuildinfo

# рабочие скриншоты dev-проверок (генерятся через chrome-devtools MCP)
/screenshots/

# дизайн-макеты — внутренняя референс-документация, не в git (хранятся локально)
/design_handoff/
/design_handoff_admin/

# внутренняя проектная дока — не в git (хранится локально, вся «парадная»/agent-дока внутренняя)
/CLAUDE.md
/README.md

# локальные настройки Claude Code (пермишены и т.п.) — никогда не коммитим
/.claude/

# исходник дизайн-системы (референс; рантайм использует копии public/css|js) — внутрянка
/_visual/

# импорт-кэш с shop-aeva.ru (~170МБ оригиналов фото + JSON) — локальный «бэкап» для re-import.
# В git не пускаем; для нового VPS достаточно `npm run import:aeva` если положить эти файлы рядом.
/imports/
