# --- ПРОДАКШН (для docker-compose.yml) ---
# Скопируй в .env рядом с compose на VPS и заполни.
DOMAIN=ceramic.example.ru
DB_PASSWORD=сгенерируй_длинный_пароль       # openssl rand -base64 32
PAYLOAD_SECRET=минимум_32_символа_рандома   # openssl rand -base64 32

# --- УВЕДОМЛЕНИЯ О ЗАЯВКАХ (опционально) ---
# Если переменные не заданы — соответствующий канал тихо пропускается.
# Telegram: создать бота через @BotFather → токен; chat_id — свой ID (узнать у @userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Email через SMTP (порт 465 = TLS, иначе STARTTLS). ORDER_EMAIL_TO — куда слать заявки.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Керамика <no-reply@ceramic.example.ru>
ORDER_EMAIL_TO=

# --- ЛОКАЛЬНАЯ РАЗРАБОТКА (npm run dev) ---
# Для dev используется отдельный .env с прямым подключением:
#   DATABASE_URI=postgres://ceramic:ceramic_secret@127.0.0.1:5435/ceramic
#   PAYLOAD_SECRET=ceramic-spike-secret-change-me
