# =============================================================================
# DEV — для docker-compose.dev.yml
# =============================================================================
# Всё уже задано inline внутри compose: app слушает :3070, Postgres :5470.
# Этот .env прода НЕ читается dev-compose'ом. Если нужен локальный .env для
# любых experiments — кладите рядом, в dev-compose он не попадёт.

# =============================================================================
# PROD (на VPS) — скопируй в .env рядом с compose на сервере и заполни
# =============================================================================
# Два режима развёртывания (одни и те же секреты, разные роутинг-переменные):
#
#  A) RAW-ПОРТ (текущий) — docker-compose.prod-port.yml + scripts/deploy-port.sh.
#     Один app-контейнер с пробросом APP_PORT, без Traefik/домена. Нужны:
#     DB_PASSWORD, PAYLOAD_SECRET, APP_PORT, NEXT_PUBLIC_SERVER_URL.
#     DOMAIN можно не задавать.
#
#  B) ДОМЕН + HTTPS (будущее) — docker-compose.prod-bg.yml + scripts/deploy.sh
#     (blue-green за Traefik). Тогда нужен DOMAIN, а APP_PORT не используется
#     (трафик идёт через Traefik по Host). Подробности перехода — в
#     _local_docs/internal/deploy/auto-deploy.md.

# --- общее (нужно в обоих режимах) ---
DB_PASSWORD=сгенерируй_длинный_пароль       # openssl rand -base64 32
PAYLOAD_SECRET=минимум_32_символа_рандома   # openssl rand -base64 32

# --- режим A (raw-порт), текущий ---
# Свободный порт на VPS (заняты: 8091 aeva, 8100/3100 vlad, 80/443 traefik).
APP_PORT=8092
# Полный внешний URL приложения (печётся в cors/csrf и клиентские ссылки).
NEXT_PUBLIC_SERVER_URL=http://5.187.2.81:8092

# --- режим B (домен), на будущее ---
# Раскомментируй и задай домен при переходе на Traefik (тогда NEXT_PUBLIC_SERVER_URL=https://${DOMAIN}).
#DOMAIN=ceramic.example.ru

# --- Уведомления о заявках (опционально) ---
# Если переменные не заданы — соответствующий канал тихо пропускается.
# Telegram: создать бота через @BotFather → токен; chat_id — свой ID (узнать у @userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Email через SMTP (порт 465 = TLS, иначе STARTTLS). ORDER_EMAIL_TO — куда слать заявки.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Керамика <no-reply@ceramic.example.ru>
ORDER_EMAIL_TO=
